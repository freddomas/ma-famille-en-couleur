{
  "name": "ma-famille-en-couleur",
  "version": "2.0.0",
  "private": true,
  "astryx": {
    "theme": "@astryxdesign/theme-neutral"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-delivery.cjs",
    "dry-run": "powershell -ExecutionPolicy Bypass -File scripts/run-browser-dry-run.ps1 -Headed",
    "assets:colored": "node scripts/regenerate-colored-guides.cjs --apply",
    "assets:svg": "node scripts/convert-catalogue-assets-to-svg.cjs --apply",
    "assets:archive-png": "node scripts/archive-decommissioned-png.cjs",
    "qa:catalogue-visibility": "node scripts/catalogue-visibility-playwright.cjs",
    "qa:image-framing": "node scripts/image-framing-playwright.cjs",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.6",
    "@astryxdesign/theme-neutral": "^0.1.6",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/bree-serif": "^5.2.8",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "imagetracerjs": "^1.2.6",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "sharp": "^0.35.3",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
